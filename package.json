{
  "name": "macromaxxing",
  "packageManager": "yarn@4.12.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "workers"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hyldmo/macromaxxing.git"
  },
  "scripts": {
    "dev": "numux 'dev:*'",
    "dev:web": "react-router dev",
    "dev:api": "yarn workspace @macromaxxing/workers dev",
    "dev:db": "yarn workspace @macromaxxing/db dev",
    "build": "react-router build && node --experimental-transform-types scripts/fix-sw.ts",
    "typecheck": "yarn generate && numux -p 'typecheck:*'",
    "typecheck:app": "tsc",
    "typecheck:scripts": "tsc -p tsconfig.node.json",
    "typecheck:packages": "numux -p -w 'typecheck'",
    "generate": "numux -p 'generate:*'",
    "generate:react-router": "react-router typegen",
    "generate:wrangler": "yarn workspace @macromaxxing/workers run generate:wrangler",
    "generate:pwa-icons": "pwa-assets-generator --preset minimal-2023 public/favicon.svg",
    "check": "numux -p 'npm:lint' 'npm:typecheck' 'npm:test'",
    "fix": "biome check . --fix --unsafe",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:generate": "yarn workspace @macromaxxing/db drizzle-kit generate && yarn db:flatten",
    "db:flatten": "for d in packages/db/drizzle/*/; do tag=$(basename \"$d\"); [ -f \"$d/migration.sql\" ] && [ ! -f \"packages/db/drizzle/${tag}.sql\" ] && sed -e 's/^CREATE TABLE /CREATE TABLE IF NOT EXISTS /; s/^CREATE INDEX /CREATE INDEX IF NOT EXISTS /; s/^CREATE UNIQUE INDEX /CREATE UNIQUE INDEX IF NOT EXISTS /' \"$d/migration.sql\" > \"packages/db/drizzle/${tag}.sql\"; done; true",
    "db:migrate": "yarn workspace @macromaxxing/workers wrangler d1 migrations apply macromaxxing --local",
    "db:migrate:remote": "yarn workspace @macromaxxing/workers wrangler d1 migrations apply macromaxxing --remote",
    "db:seed": "yarn db:migrate && yarn workspace @macromaxxing/workers wrangler d1 execute macromaxxing --local --file=scripts/seed.sql",
    "db:seed:usda": "node --experimental-transform-types scripts/seed-usda.ts",
    "db:seed:generate": "node --experimental-transform-types scripts/seed.ts",
    "db:copy-to-prod": "node --experimental-transform-types scripts/copy-to-prod.ts",
    "db:copy-from-prod": "node --experimental-transform-types scripts/copy-from-prod.ts",
    "test": "vitest run",
    "postinstall": "prek install && prek install --hook-type commit-msg"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.36",
    "@ai-sdk/google": "^3.0.21",
    "@ai-sdk/openai": "^3.0.25",
    "@cfworker/json-schema": "^4.1.1",
    "@clerk/clerk-react": "^5.61.6",
    "@clerk/themes": "^2.4.60",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hyldmo/by": "^1.1.0",
    "@macromaxxing/db": "workspace:*",
    "@mdxeditor/editor": "^3.52.3",
    "@react-router/dev": "^7.15.0",
    "@react-router/fs-routes": "^7.15.0",
    "@react-router/node": "^7.15.0",
    "@tanstack/query-persist-client-core": "^5.91.19",
    "@tanstack/react-query": "^5.90.20",
    "@trpc/client": "^11.9.0",
    "@trpc/react-query": "^11.9.0",
    "@trpc/server": "^11.9.0",
    "ai": "^6.0.71",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "es-toolkit": "^1.44.0",
    "html5-qrcode": "^2.3.8",
    "idb-keyval": "^6.2.2",
    "isbot": "^5",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.15.0",
    "tailwind-merge": "^3.4.0",
    "ts-extras": "^0.17.0",
    "vite-plugin-pwa": "^1.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@j178/prek": "^0.3.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "numux": "^2.10.3",
    "semantic-release": "^25.0.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
